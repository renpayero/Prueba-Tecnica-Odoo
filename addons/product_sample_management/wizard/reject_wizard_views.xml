<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                   WIZARD: RECHAZO DE MUESTRA                -->
    <!-- ============================================================ -->
    <record id="view_product_sample_reject_wizard_form" model="ir.ui.view">
        <field name="name">product.sample.reject.wizard.form</field>
        <field name="model">product.sample.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rechazar muestra">
                <group>
                    <field name="sample_request_id" invisible="1"/>
                    <field name="reject_reason" placeholder="Indique el motivo del rechazo..."/>
                </group>
                <footer>
                    <button name="action_reject" string="Confirmar rechazo"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
