<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--            HERENCIA VISTA FORM DE RES.PARTNER               -->
    <!-- ============================================================ -->
    <record id="view_partner_form_inherit_sample" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.sample</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sample_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-flask">
                    <field name="sample_count" widget="statinfo"
                           string="Muestras"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
