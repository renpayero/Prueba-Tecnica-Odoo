<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                        FORM VIEW                            -->
    <!-- ============================================================ -->
    <record id="view_product_sample_request_form" model="ir.ui.view">
        <field name="name">product.sample.request.form</field>
        <field name="model">product.sample.request</field>
        <field name="arch" type="xml">
            <form string="Solicitud de muestra">
                <header>
                    <!-- Botones de acción contextuales según estado -->
                    <button name="action_confirm" string="Confirmar solicitud"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"
                            groups="product_sample_management.group_sample_manager"/>
                    <button name="action_send" string="Marcar como enviado"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'confirmed')]}"
                            groups="product_sample_management.group_sample_manager"/>
                    <button name="action_receive" string="Recibido"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'sent')]}"
                            groups="product_sample_management.group_sample_manager"/>
                    <button name="action_reject" string="Rechazado"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('state', '!=', 'sent')]}"
                            groups="product_sample_management.group_sample_manager"/>
                    <button name="action_draft" string="Volver a borrador"
                            type="object"
                            attrs="{'invisible': [('state', '!=', 'confirmed')]}"/>
                    <button name="action_cancel" string="Cancelar"
                            type="object"
                            attrs="{'invisible': [('state', 'not in', ['draft', 'confirmed'])]}"
                            confirm="¿Está seguro de cancelar esta solicitud?"/>
                    <!-- Barra de estado -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,sent,received"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información de la solicitud">
                            <field name="partner_id"
                                   attrs="{'readonly': [('state', 'in', ['received', 'rejected', 'cancelled'])]}"/>
                            <field name="product_id"
                                   attrs="{'readonly': [('state', 'in', ['received', 'rejected', 'cancelled'])]}"/>
                            <field name="quantity"
                                   attrs="{'readonly': [('state', 'in', ['received', 'rejected', 'cancelled'])]}"/>
                            <field name="request_date"
                                   attrs="{'readonly': [('state', 'in', ['received', 'rejected', 'cancelled'])]}"/>
                        </group>
                        <group string="Datos adicionales">
                            <field name="user_id"
                                   attrs="{'readonly': [('state', 'in', ['received', 'rejected', 'cancelled'])]}"/>
                            <field name="total_requests"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observaciones">
                            <field name="notes"
                                   placeholder="Observaciones internas..."
                                   attrs="{'readonly': [('state', 'in', ['received', 'rejected', 'cancelled'])]}"/>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                        TREE VIEW                            -->
    <!-- ============================================================ -->
    <record id="view_product_sample_request_tree" model="ir.ui.view">
        <field name="name">product.sample.request.tree</field>
        <field name="model">product.sample.request</field>
        <field name="arch" type="xml">
            <tree string="Solicitudes de muestra"
                  decoration-success="state == 'received'"
                  decoration-danger="state in ('rejected', 'cancelled')"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="request_date"/>
                <field name="user_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'received'"
                       decoration-danger="state in ('rejected', 'cancelled')"
                       decoration-info="state in ('confirmed', 'sent')"
                       decoration-muted="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       KANBAN VIEW                           -->
    <!-- ============================================================ -->
    <record id="view_product_sample_request_kanban" model="ir.ui.view">
        <field name="name">product.sample.request.kanban</field>
        <field name="model">product.sample.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="request_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><strong>Cliente:</strong> <field name="partner_id"/></div>
                                    <div><strong>Producto:</strong> <field name="product_id"/></div>
                                    <div><strong>Fecha:</strong> <field name="request_date"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                       SEARCH VIEW                           -->
    <!-- ============================================================ -->
    <record id="view_product_sample_request_search" model="ir.ui.view">
        <field name="name">product.sample.request.search</field>
        <field name="model">product.sample.request</field>
        <field name="arch" type="xml">
            <search string="Buscar solicitudes de muestra">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <!-- Filtros predefinidos -->
                <filter name="filter_my_samples" string="Mis muestras"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="filter_pending_send" string="Pendientes de envío"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_received_this_month" string="Recibidas este mes"
                        domain="[('state', '=', 'received'),
                                 ('request_date', '&gt;=', (context_today()).strftime('%%Y-%%m-01'))]"/>
                <separator/>
                <!-- Agrupaciones predefinidas -->
                <group expand="0" string="Agrupar por">
                    <filter name="group_partner" string="Por cliente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Por estado"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="Por comercial"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                     WINDOW ACTION                           -->
    <!-- ============================================================ -->
    <record id="action_product_sample_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de muestra</field>
        <field name="res_model">product.sample.request</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_product_sample_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cree su primera solicitud de muestra
            </p>
            <p>
                Gestione las solicitudes de muestras de producto de sus clientes.
            </p>
        </field>
    </record>

</odoo>
